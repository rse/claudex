{
    "compilerOptions": {
		"outDir":                  ".",
        "target":                  "esnext",
        "module":                  "nodenext",
        "moduleResolution":        "nodenext",
        "useDefineForClassFields": true,
        "composite":               false,
        "strict":                  true,
        "resolveJsonModule":       true,
        "isolatedModules":         true,
        "esModuleInterop":         true,
        "lib":                     [ "ESNext" ],
        "skipLibCheck":            true,
        "noEmit":                  false,
        "types":                   [ "node" ],
        "rootDir":                 "."
    },
    "files": [
        "claudex.ts",
        "claude-statusline.ts"
    ]
}
