#   find our base directory
basedir=""
case "$0" in
    /* )
        #   absolute path
        basedir=$(dirname "$0")
        ;;
    */* )
        #   relative path
        basedir=$(dirname "$0")
        basedir=$(cd "$basedir" && pwd)
        ;;
    * )
        if [[ -f "./$0" ]]; then
            #   special case of local usage
            basedir=$(pwd)
        else
            #   no path
            OLD_IFS="$IFS"; IFS=":"
            for p in $PATH; do
                IFS="$OLD_IFS"
                if [[ -f "$p/$0" ]]; then
                    basedir="$p"
                    break
                fi
            done
            IFS="$OLD_IFS"
        fi
        ;;
esac

#   sanity check usage
if [[ $# -eq 0 ]]; then
    echo "claudex: ERROR: missing command" 1>&2
    echo "claudex: USAGE: claudex install" 1>&2
    echo "claudex: USAGE: claudex update" 1>&2
    echo "claudex: USAGE: claudex session" 1>&2
    echo "claudex: USAGE: claudex shell [...]" 1>&2
    echo "claudex: USAGE: claudex claude [...]" 1>&2
    exit 1
fi

#   support special "-h" (host) option
host=no
if [[ $# -ge 1 && $1 == "-h" ]]; then
    shift
    host=yes
fi

#   determine terminal colors
_term_colors=$(tput colors 2>/dev/null)
if [[ -n $_term_colors && $_term_colors -ge 8 ]]; then
    #   determine terminal color sequences
    col_bd=$'\e[1m'
    col_bl=$'\e[34m'
    col_rd=$'\e[31m'
    col_gr=$'\e[37m'
    col_no=$'\e[0m'
else
    #   fallback to no coloring
    col_bd=""
    col_bl=""
    col_rd=""
    col_gr=""
    col_no=""
fi

#   helper function for displaying info messages
info () {
    local msg="$*"
    echo "${col_bl}claudex: ${col_bd}INFO:${col_no}${col_bl} $msg${col_no}" 1>&2
}

#   helper function for raising a fatal error
fatal () {
    local msg="$*"
    echo "${col_rd}claudex: ${col_bd}ERROR:${col_no}${col_rd} $msg${col_no}" 1>&2
    exit 1
}

#   helper function to ensure a tool is available
ensureTool () {
    local tool="$1"
    if ! command -v "$tool" >/dev/null 2>&1; then
        fatal "required tool \"$tool\" not found in \$PATH"
    fi
}

#   dispatch according to command
cmd="$1"; shift
case "$cmd" in
    version )
        VERSION=$(cat $basedir/VERSION.txt)
        echo "claudeX $VERSION"
        ;;

    install )
        #   sanity check environment
        if [[ $ENVIRONMENT == "capsula" ]]; then
            fatal "cannot execute \"install\" command from within Capsula environment"
        fi

        #   ensure we are not running from the home directory
        #   in order to not read-write mount its ~/.local/!
        cd $basedir || fatal "cannot switch to base directory"

        #   dispatch according to host/container mode
        if [[ $host == no ]]; then
            info "update Debian GNU/Linux operating system"
            $0 shell -s sudo -E apt update -qq
            $0 shell -s sudo -E apt upgrade -qq -y

            info "install Tmux / LF / LazyGit / FZF / RipGrep / Git"
            $0 shell -s sudo -E apt install -qq -y tmux lf lazygit fzf ripgrep git

            info "install Bat"
            $0 shell -s sudo -E apt install -qq -y bat
            $0 shell -s sudo -E ln -f /usr/bin/batcat /usr/bin/bat
            cmd="export BAT_CONFIG_DIR=/etc/bat; export BAT_CACHE_PATH=/etc/bat;"
            cmd="$cmd mkdir -p \$BAT_CONFIG_DIR/themes; cp $basedir/bat.tmTheme \$BAT_CONFIG_DIR/themes/;"
            cmd="$cmd bat cache --build"
            $0 shell -s sudo -E bash -c "$cmd"

            info "install Node.js"
            $0 shell -s sudo -E bash -c "curl -fsSL https://deb.nodesource.com/setup_24.x | bash -"
            $0 shell -s sudo -E apt install -qq -y nodejs
            $0 shell -s sudo -E apt install -qq -y binutils gcc g++ make

            info "install Claude Code"
            $0 shell bash -c "rm -f \$HOME/.local/bin/claude"
            $0 shell bash -c "rm -f \$HOME/.local/share/claude/versions/*"
            $0 shell bash -c "PATH=\"$HOME/.local/bin:\$PATH\"; curl -kfsSL https://claude.ai/install.sh | bash"

            info "install ANSI-Recolor"
            $0 shell -s sudo -E npm install -y -g ansi-recolor

            info "install TypeScript LS"
            $0 shell -s sudo -E npm install -y -g typescript-language-server

            info "install CCUsage"
            $0 shell -s sudo -E npm install -y -g ccusage

            info "install Claude wrapper"
            $0 shell -s sudo install -c -m 755 $basedir/claude /usr/bin/claude
        else
            info "install Claude Code (on host)"
            rm -f $HOME/.local/bin/claude
            rm -f $HOME/.local/share/claude/versions/*
            (PATH="$HOME/.local/bin:$PATH"; curl -kfsSL https://claude.ai/install.sh | bash)
        fi
        ;;

    update )
        #   sanity check environment
        if [[ $ENVIRONMENT == "capsula" ]]; then
            fatal "cannot execute \"install\" command from within Capsula environment"
        fi

        #   ensure we are not running from the home directory
        #   in order to not read-write mount its ~/.local/!
        cd $basedir || fatal "cannot switch to base directory"

        #   dispatch according to host/container mode
        if [[ $host == no ]]; then
            info "update Debian GNU/Linux operating system"
            $0 shell -s sudo apt update -qq
            $0 shell -s sudo apt upgrade -qq -y

            info "update Bat"
            cmd="export BAT_CONFIG_DIR=/etc/bat; export BAT_CACHE_PATH=/etc/bat;"
            cmd="$cmd mkdir -p \$BAT_CONFIG_DIR/themes; cp $basedir/bat.tmTheme \$BAT_CONFIG_DIR/themes/;"
            cmd="$cmd bat cache --build"
            $0 shell -s sudo -E bash -c "$cmd"

            info "update Claude Code"
            $0 shell bash -c "PATH=\"$HOME/.local/bin:\$PATH\"; $HOME/.local/bin/claude update"

            info "update ANSI-Recolor"
            $0 shell -s sudo -E npm install -y -g ansi-recolor

            info "update TypeScript LS"
            $0 shell -s sudo -E npm install -y -g typescript-language-server

            info "update CCUsage"
            $0 shell -s sudo -E npm install -y -g ccusage

            info "update Claude wrapper"
            $0 shell -s sudo install -c -m 755 $basedir/claude /usr/bin/claude
        else
            info "update Claude Code (on host)"
            (PATH="$HOME/.local/bin:$PATH"; $HOME/.local/bin/claude update)
        fi
        ;;

    session )
        #   sanity check environment
        if [[ $ENVIRONMENT == "capsula" ]]; then
            fatal "cannot execute \"session\" command from within Capsula environment"
        fi

        #   determine session name
        session=default
        if [[ $# -ge 1 ]]; then
            session="$1"
            shift
        else
            dir="$(pwd)"
            while [[ "$dir" != "/" ]]; do
                if [[ -f "$dir/AGENTS.md" || -f "$dir/CLAUDE.md" ]]; then
                    session="$(basename "$dir")"
                    break
                fi
                dir="$(dirname "$dir")"
            done
        fi

        #   dispatch according to environment
        if [[ $host == no ]]; then
            #   enter/start container
            container="capsula-$USER-debian-claude-$session"
            if docker inspect $container >/dev/null 2>&1; then
                #   enter already running container and run tmux
                exec docker exec -i -t "$container" \
                    bash -c "TERM=$TERM HOME=$HOME sudo -E -u $USER $0 util tmux new-session -A -s \"$session\""
            else
                #   start a new container and run tmux
                exec $0 shell -C $container $0 util tmux new-session -A -s "$session" -n "claude" "$0 claude"
            fi
        else
            #   enter/start plain tmux
            exec $0 util tmux new-session -A -s "$session" -n "claude" "$0 claude"
        fi
        ;;

    naked )
        #   sanity check environment
        if [[ $ENVIRONMENT == "capsula" ]]; then
            fatal "cannot execute \"naked\" command from within Capsula environment"
        fi

        #   dispatch according to environment
        if [[ $host == no ]]; then
            #   enter/start container
            container="capsula-$USER-debian-claude-$session"
            if docker inspect $container >/dev/null 2>&1; then
                #   enter already running container and run claude
                exec docker exec -i -t "$container" \
                    bash -c "TERM=$TERM HOME=$HOME sudo -E -u $USER $0 claude $@"
            else
                #   start a new container and run claude
                exec $0 shell -C $container $0 claude ${1+"$@"}
            fi
        else
            #   enter/start plain claude
            exec $0 claude ${1+"$@"}
        fi
        ;;

    shell )
        #   sanity check environment
        ensureTool capsula
        if [[ $ENVIRONMENT == "capsula" ]]; then
            fatal "cannot execute \"shell\" command from within Capsula environment"
        fi

        #   define list of environment variables
        envs=(
            TERM
            HOME
        )
        env_opts=(-e '!')
        for env in "${envs[@]}"; do
            env_opts+=(-e "$env")
        done

        #   find list of dot-files (relative to $HOME)
        dotfiles=(
            .inputrc
            .dotfiles/inputrc
            .bash_login
            .bash_logout
            .bashrc
            .dotfiles/bashrc
            .ssh/authorized_keys
            .ssh/known_hosts!
            .ssh/config
            .dotfiles/sshconfig
            .vimrc
            .dotfiles/vimrc
            .vim
            .tmux.conf
            .dotfiles/tmux.conf
            .gitconfig
            .dotfiles/gitconfig
            .npmrc
            .npm!
            .cache!
            .claude!
            .claude.json!
        )
        dotfile_opts=(-m '!')
        for dotfile in "${dotfiles[@]}"; do
            path="${dotfile%!}"
            if [ -e "$HOME/$path" ]; then
                dotfile_opts+=(-m "$dotfile")
            fi
        done

        #   find all sensitive ".env" files from current working
        #   directory up to root directory for hiding
        null_opts=(-n '!')
        dir="$PWD"
        while true; do
            if [ -f "$dir/.env" ]; then
                null_opts+=(-n "$dir/.env")
            fi
            if [ "$dir" = "/" ]; then
                break
            fi
            dir="$(dirname "$dir")"
        done

        #   execute
        exec capsula \
            -c claude \
            -t debian \
            -P linux/arm64 \
            "${env_opts[@]}" \
            "${dotfile_opts[@]}" \
            "${null_opts[@]}" \
            -p '!' \
            -e "CLAUDE_MODEL=${CLAUDE_MODEL-""}" \
            -e "CLAUDEX=$basedir" \
            -b "$basedir" \
            -b "/Users/rse/Work/ase" \
            "$@"
        #   FIXME: remove "-b /Users/rse/Work/ase" for non-debugging purposes
        ;;

    claude )
        #   execute Claude Code
        PATH=$HOME/.local/bin:$PATH
        ensureTool ansi-recolor
        ensureTool claude
        ensureTool node
        ensureTool npm
        if [[ $CLAUDE_MODEL =~ ^ollama: ]]; then
            #   parse ollama[://<host>[:<port>]]/<model>[?[context=<size>],[capabilities=<list>]]
            remainder="${CLAUDE_MODEL#ollama:}"
            host="localhost:11434"
            if [[ $remainder == //* ]]; then
                remainder="${remainder#//}"
                host="${remainder%%/*}"
                remainder="${remainder#*/}"
            else
                remainder="${remainder#/}"
            fi
            model="${remainder%%\?*}"
            context="200k"
            capabilities=""
            if [[ $remainder == *"?"* ]]; then
                query="${remainder#*\?}"
                IFS="," read -ra pairs <<< "$query"
                for pair in "${pairs[@]}"; do
                    key="${pair%%=*}"
                    val="${pair#*=}"
                    case "$key" in
                        context )      context="$val"      ;;
                        capabilities ) capabilities="$val" ;;
                    esac
                done
            fi

            #   override Claude Code configuration
            export "ANTHROPIC_BASE_URL=http://$host"
            export "ANTHROPIC_API_KEY="
            export "ANTHROPIC_AUTH_TOKEN=ollama"
            export "CLAUDE_CODE_ATTRIBUTION_HEADER=0"
            export "ANTHROPIC_DEFAULT_OPUS_MODEL=$model"
            export "ANTHROPIC_DEFAULT_SONNET_MODEL=$model"
            export "ANTHROPIC_DEFAULT_HAIKU_MODEL=$model"
            export "CLAUDE_CODE_SUBAGENT_MODEL=$model"
            export "CLAUDE_CODE_AUTO_COMPACT_WINDOW=$context"
            export "ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES=$capabilities"
            export "DISABLE_LOGIN_COMMAND=1"
            export "DISABLE_LOGOUT_COMMAND=1"
        fi
        exec ansi-recolor \
            -c $basedir/ansi-recolor.conf \
            -m \
            -n claude \
            -t $HOME/ansi-recolor.txt \
            $HOME/.local/bin/claude \
                --settings "$(sed <$basedir/claude-settings.json -e "s;@BASEDIR@;$basedir;g")" \
                ${1+"$@"}
        ;;

    util )
        util="$1"; shift
        case "$util" in
            tmux )
                ensureTool tmux
                exec tmux -f "$basedir/tmux.conf" \
                    bind-key c   new-window    -c "#{pane_current_path}" -n "claude" "$0 claude" \; \
                    bind-key "|" split-window  -c "#{pane_current_path}" -h          "$0 claude" \; \
                    bind-key "-" split-window  -c "#{pane_current_path}" -v          "$0 claude" \; \
                    bind-key g display-popup -E -w "95%" -h "95%" \
                        -T "─◀#[reverse] ⧉ Version Control (lazygit) #[noreverse]▶" "$0 util lazygit" \; \
                    bind-key b display-popup -E -w "95%" -h "95%" \
                        -T "─◀#[reverse] ⧉ Shell (bash) #[noreverse]▶"              "$0 util bash" \; \
                    bind-key s display-popup -E -w "95%" -h "95%" \
                        -T "─◀#[reverse] ⧉ Search Content (sc) #[noreverse]▶"       "$0 util sc" \; \
                    bind-key f display-popup -E -w "95%" -h "95%" \
                        -T "─◀#[reverse] ⧉ File Browser (lf) #[noreverse]▶"         "$0 util lf" \; \
                    ${1+"$@"}
                ;;
            sc )
                ensureTool fzf
                ensureTool rg
                ensureTool bat
                ensureTool vim
                if [[ $ENVIRONMENT == "capsula" ]]; then
                    export BAT_CONFIG_DIR=/etc/bat
                    export BAT_CACHE_PATH=/etc/bat
                    export BAT_THEME=bat
                fi
                exec bash $basedir/sc.bash ${1+"$@"}
                ;;
            lf )
                ensureTool ansi-recolor
                ensureTool lf
                ensureTool vim
                exec ansi-recolor \
                    -c $basedir/ansi-recolor.conf \
                    -m \
                    -n lf \
                    -t $HOME/ansi-recolor.txt \
                    lf -config $basedir/lf.conf ${1+"$@"}
                ;;
            bash )
                ensureTool bash
                exec bash -l ${1+"$@"}
                ;;
            lazygit )
                ensureTool ansi-recolor
                ensureTool git
                ensureTool lazygit
                ensureTool vim
                export TERM=xterm-color
                exec ansi-recolor \
                    -c $basedir/ansi-recolor.conf \
                    -m \
                    -n lazygit \
                    -t $HOME/ansi-recolor.txt \
                    lazygit -ucf $basedir/lazygit.yaml ${1+"$@"}
                ;;
        esac
        ;;

    * )
        fatal "invalid command \"$cmd\""
        ;;
esac

