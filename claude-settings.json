{
    "env": {
        "DISABLE_TELEMETRY": "1",
        "DISABLE_AUTOUPDATER": "1",
        "DISABLE_BUG_COMMAND": "1",
        "DISABLE_ERROR_REPORTING": "1",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "statusLine": {
        "type": "command",
        "command": "ase statusline -w 0 -m 2 '<blue>%u</blue> <red>%p</red> <black>%T</black> %s' '%m %e %t' '%P %c'",
        "padding": 0
    },
    "verbose": false,
    "teammateMode": "tmux",
    "preferences": {
        "tmuxSplitPanes": true
    }
}
